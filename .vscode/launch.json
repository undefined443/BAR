{
  "version": "0.2.0",
  "configurations": [
    {
      "name": "train_bar",
      "type": "debugpy",
      "request": "launch",
      "cwd": "${workspaceFolder}",
      "python": ".venv/bin/python",
      "program": "${workspaceFolder}/scripts/train_bar.py",
      "args": [
        "config=configs/generator/bar_b.yaml",
        "training.per_gpu_batch_size=1",
        "training.gradient_accumulation_steps=1",
        "dataset.params.pretokenization=pretokenized_npz",
        "dataset.params.train_shards_path_or_url=ImageNet-1K-wds/imagenet-train-000000.tar",
        "dataset.params.eval_shards_path_or_url=ImageNet-1K-wds/imagenet-val-000000.tar"
      ],
      "env": {
        "PYTHONPATH": "${workspaceFolder}",
        "OMP_NUM_THREADS": "1"
      },
      "console": "integratedTerminal",
      "justMyCode": true
    }
  ]
}
